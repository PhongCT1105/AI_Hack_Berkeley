{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
    "magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "${MAGIC_21ST_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "agentshield": {
      "command": "/Users/Doanh/Documents/Projects/AIHackBerk/backend/.venv/bin/python",
      "args": [
        "/Users/Doanh/Documents/Projects/AIHackBerk/backend/mcp_server.py"
      ],
      "env": {
        "AGENTSHIELD_API_URL": "http://localhost:8000"
      }
    }
  }
}
