# Copy to .env and fill in. Never commit the real .env.
# EVERYTHING below is optional — AgentShield boots and returns a valid heuristic
# verdict with none of these set. Each key just upgrades one stage.
APP_NAME="Captain America API"
DEBUG=true
CORS_ORIGINS="http://localhost:3000"

# Claude extractor + credibility capsule (Anthropic SDK). Absent -> heuristic.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# The Token Company automatic prompt compression. When set, all Anthropic
# messages.create calls are wrapped before Claude receives them.
# TTC_API_KEY=ttc-...
# TTC_COMPRESSION_MODEL=bear-2
# TTC_AGGRESSIVENESS=0.2
# TTC_APP_ID=captain-america

# Firecrawl supports two distinct paths:
# - source scoring can fall back to direct HTTP for a supplied URL;
# - prompt-driven research discovery requires Firecrawl Search and returns an
#   explicit configuration error when this key is absent.
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev

# Citation-usability model. The default path is written by
# scripts/train_citation_classifier.py. A source must pass the normal trust
# ranker and this probability threshold before research will cite it.
# CITATION_MODEL_PATH=data/sourceguard_citation_classifier.joblib
# CITATION_MODEL_MIN_PROBABILITY=0.50

# Prompt-driven research agent. A run can inspect up to 100 sources; keep the
# concurrency conservative to respect source sites and Firecrawl limits.
# RESEARCH_MAX_SOURCES=100
# RESEARCH_CONCURRENCY=6

# Redis cache + rolling reputation. Absent -> in-memory cache.
# REDIS_URL=redis://localhost:6379/0

# Observability. Absent -> disabled / no-op tracer. Arize AX is preferred when
# both keys below are set; otherwise falls back to Phoenix, then a no-op tracer.
# SENTRY_DSN=
# ARIZE_SPACE_ID=
# ARIZE_API_KEY=
# ARIZE_PROJECT_NAME=captain-america
# PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
# PHOENIX_API_KEY=

# Terac (human-in-the-loop arena). Absent -> local-only stub arena.
# TERAC_API_KEY=
# TERAC_API_URL is Terac's MCP endpoint (https://terac.com/api/mcp), NOT a
# plain REST base — app/ml/terac_mcp_client.py speaks MCP (JSON-RPC) to it.
# TERAC_API_URL=
# TERAC_PROJECT_ID=

# Auto-launch: when a scored source misses the trust/citation threshold, the
# pipeline fetches a fresh candidate (Firecrawl), inserts a Supabase
# source_claim_tasks row, and posts a REAL paid Terac opportunity to get it
# labeled. TERAC_AUTO_LAUNCH_TASK_URL must be a publicly reachable page (a
# tunnel or deployed frontend route) — Terac participants open it directly;
# localhost will not work. Cooldown + max-total bound the spend.
# TERAC_AUTO_LAUNCH_MODE=draft is free (creates the opportunity, no
# recruitment/charge until a human calls terac_launch_draft_opportunity);
# "launch" also launches it immediately and spends real money.
# TERAC_AUTO_LAUNCH_MODE=draft
# TERAC_AUTO_LAUNCH_TASK_URL=https://example.com/terac/review-stub
# TERAC_AUTO_LAUNCH_PARTICIPANTS=1
# TERAC_AUTO_LAUNCH_MAX_TOTAL=10
# TERAC_AUTO_LAUNCH_COOLDOWN_HOURS=24

# Degradation monitor: how many /api/score-source calls between automatic
# degradation checks (manual trigger is always POST /api/monitor/run).
# MONITOR_CHECK_EVERY_N_CALLS=20

# Supabase labeled-task export. Keep the key server-side (service_role key from
# Settings -> API Keys); do not add it to frontend/.env.local. Labels live in a
# separate annotations table (many rows per task), joined by SUPABASE_JOIN_KEY.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_KEY=
# SUPABASE_TASKS_TABLE=source_claim_tasks
# SUPABASE_ANNOTATIONS_TABLE=simple_claim_annotations
# SUPABASE_JOIN_KEY=task_id
# SUPABASE_LABEL_COLUMN=can_ai_cite
