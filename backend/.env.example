# Copy to .env and fill in. Never commit the real .env.
# EVERYTHING below is optional — AgentShield boots and returns a valid heuristic
# verdict with none of these set. Each key just upgrades one stage.
APP_NAME="AgentShield API"
DEBUG=true
CORS_ORIGINS="http://localhost:3000"

# Claude extractor + credibility capsule (Anthropic SDK). Absent -> heuristic.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# Browserbase collector (use STARTERPACK for free Developer plan). Absent -> httpx fallback.
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# Prompt-driven research agent. A run can inspect up to 100 sources; keep the
# concurrency conservative to respect websites and Browserbase session limits.
# RESEARCH_MAX_SOURCES=100
# RESEARCH_CONCURRENCY=6

# Redis cache + rolling reputation. Absent -> in-memory cache.
# REDIS_URL=redis://localhost:6379/0

# Observability. Absent -> disabled / no-op tracer.
# SENTRY_DSN=
# PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
# PHOENIX_API_KEY=

# Terac (human-in-the-loop arena). Absent -> local-only stub arena.
# A teammate wires the real Terac API/MCP — see app/ml/trainer.py TODO(terac).
# TERAC_API_KEY=

# Supabase labeled-task export. Keep the key server-side (service_role key from
# Settings -> API Keys); do not add it to frontend/.env.local. Labels live in a
# separate annotations table (many rows per task), joined by SUPABASE_JOIN_KEY.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_KEY=
# SUPABASE_TASKS_TABLE=source_claim_tasks
# SUPABASE_ANNOTATIONS_TABLE=simple_claim_annotations
# SUPABASE_JOIN_KEY=task_id
# SUPABASE_LABEL_COLUMN=can_ai_cite
